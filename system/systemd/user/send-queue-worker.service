[Unit]
Description=OpenClaw Job Queue Worker (file sending + SageMath)
After=openclaw-gateway.service

[Service]
Type=simple
ExecStart={{ HOME }}/.openclaw/workspace/skills/zotero/job_queue_worker.sh
Environment=PATH={{ HOME }}/.npm-global/bin:/usr/local/bin:/usr/bin:/bin
Environment=OPENCLAW_WORKSPACE={{ HOME }}/.openclaw/workspace
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
