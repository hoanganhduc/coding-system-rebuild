[Unit]
Description=RSS Research Radar Bot (oneshot+summary)
After=network.target

[Service]
Type=oneshot
ExecStart={{ HOME }}/.openclaw/workspace/skills/rss-news-digest/run_and_summarize.sh
Environment=PYTHONUNBUFFERED=1
Environment=OPENCLAW_WORKSPACE={{ HOME }}/.openclaw/workspace

[Install]
WantedBy=default.target
