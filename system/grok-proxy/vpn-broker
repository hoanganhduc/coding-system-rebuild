class BrokerError(RuntimeError):
    pass


class ExactCgroupV2Scope:
    """Root operation ownership backed only by an exact cgroup-v2 child."""

    def __init__(
        self,
        expected_uid: int,
        *,
        mount_root: Path = Path("/sys/fs/cgroup"),
        proc_root: Path = Path("/proc"),
        sleeper: Callable[[float], None] = time.sleep,
    ) -> None:
        self.expected_uid = expected_uid
        self.mount_root = mount_root
        self.proc_root = proc_root
        self.sleeper = sleeper

    @staticmethod
    def _read_bounded(path: Path, maximum: int) -> str:
        flags = os.O_RDONLY | os.O_CLOEXEC | getattr(os, "O_NOFOLLOW", 0)
        fd = os.open(path, flags)
        try:
            data = bytearray()
            while len(data) <= maximum:
                chunk = os.read(fd, min(16_384, maximum + 1 - len(data)))
                if not chunk:
                    break
                data.extend(chunk)
            if len(data) > maximum:
                raise BrokerError(f"oversized cgroup record: {path}")
        finally:
            os.close(fd)
        try:
            return data.decode("ascii")
        except UnicodeDecodeError as exc:
            raise BrokerError(f"non-ASCII cgroup record: {path}") from exc

    def _mount_is_cgroup2(self) -> None:
        root = self.mount_root.lstat()
        if self.mount_root.is_symlink() or not stat.S_ISDIR(root.st_mode):
            raise BrokerError("cgroup-v2 mount root is unsafe")
        mountinfo = self._read_bounded(self.proc_root / "self/mountinfo", 1_048_576)
        for line in mountinfo.splitlines():
            fields = line.split()
            try:
                split = fields.index("-")
            except ValueError:
                continue
            if (
                len(fields) > split + 2
                and fields[4].replace("\\040", " ") == str(self.mount_root)
                and fields[split + 1] == "cgroup2"
                and "rw" in fields[5].split(",")
            ):
                return
        raise BrokerError("writable cgroup-v2 mount is unavailable")

    def _current_parent(self) -> Path:
        self._mount_is_cgroup2()
        record = self._read_bounded(self.proc_root / "self/cgroup", 16_384)
        rows = record.splitlines()
        if len(rows) != 1 or not rows[0].startswith("0::/"):
            raise BrokerError("broker is not in one unified cgroup-v2 hierarchy")
        relative = rows[0][3:]
        if not relative.startswith("/") or ".." in Path(relative).parts:
            raise BrokerError("broker cgroup path is not canonical")
        # The public broker runs as root.  Anchor its ownership root directly
        # below the root-owned cgroup mount instead of below a caller-owned
        # delegated systemd scope.  Non-root test instances remain confined to
        # their delegated current cgroup.
        if self.expected_uid == 0:
            return self.mount_root
        return self.mount_root / relative.lstrip("/")

    def _base(self) -> tuple[Path, os.stat_result]:
        current = self._current_parent()
        current_info = current.lstat()
        if current.is_symlink() or not stat.S_ISDIR(current_info.st_mode):
            raise BrokerError("broker cgroup parent is unsafe")
        base = current / f"grok-vpn-broker-{self.expected_uid}"
        try:
            base.mkdir(mode=0o755)
        except FileExistsError:
            pass
        info = base.lstat()
        if (
            base.is_symlink()
            or not stat.S_ISDIR(info.st_mode)
            or info.st_uid != self.expected_uid
            or info.st_dev != current_info.st_dev
            or (
                self.expected_uid == 0
                and stat.S_IMODE(info.st_mode) & 0o022
            )
        ):
            raise BrokerError("broker operation cgroup parent is unsafe")
        return base, info

    def plan(
        self, preserve: tuple[dict[str, Any], ...] = ()
    ) -> dict[str, Any]:
        parent, info = self._base()
        preserved: dict[Path, dict[str, Any]] = {}
        for record in preserve:
            if not self.shape(record, created=True):
                raise BrokerError("invalid preserved VPN cgroup identity")
            if (
                record["parent_path"] != str(parent)
                or (record["parent_device"], record["parent_inode"])
                != (info.st_dev, info.st_ino)
            ):
                raise BrokerError("preserved VPN cgroup has another parent")
            self._verify_scope(record)
            preserved[Path(record["scope_path"])] = record
        # A broker killed between cgroup creation and durable publication can
        # leave only an empty, effect-free scope.  Prune only exact-name empty
        # children; populated scopes remain untouched and must be reconciled
        # through their durable identity.
        for child in parent.iterdir():
            if _SCOPE_NAME.fullmatch(child.name) is None:
                continue
            try:
                child_info = child.lstat()
                if (
                    child.is_symlink()
                    or not stat.S_ISDIR(child_info.st_mode)
                    or child_info.st_uid != self.expected_uid
                ):
                    raise BrokerError("unsafe unrecorded operation cgroup")
                if child in preserved:
                    if (
                        child_info.st_dev,
                        child_info.st_ino,
                    ) != (
                        preserved[child]["scope_device"],
                        preserved[child]["scope_inode"],
                    ):
                        raise BrokerError("preserved VPN cgroup identity changed")
                    continue
                events = self._read_bounded(child / "cgroup.events", 4_096)
                if "populated 0" in events.splitlines():
                    os.rmdir(child)
                else:
                    raise BrokerError("unrecorded populated VPN cgroup blocks mutation")
            except FileNotFoundError:
                continue
        return {
            "backend": _SCOPE_BACKEND,
            "parent_path": str(parent),
            "parent_device": info.st_dev,
            "parent_inode": info.st_ino,
            "scope_path": str(parent / f"grok-vpn-{secrets.token_hex(12)}"),
            "scope_device": None,
            "scope_inode": None,
        }

    @staticmethod
    def shape(value: Any, *, created: bool | None = None) -> bool:
        if type(value) is not dict or set(value) != {
            "backend", "parent_path", "parent_device", "parent_inode",
            "scope_path", "scope_device", "scope_inode",
        }:
            return False
        try:
            parent = Path(value["parent_path"])
            scope = Path(value["scope_path"])
        except TypeError:
            return False
        valid = (
            value["backend"] == _SCOPE_BACKEND
            and parent.is_absolute()
            and scope.is_absolute()
            and scope.parent == parent
            and _SCOPE_NAME.fullmatch(scope.name) is not None
            and type(value["parent_device"]) is int
            and value["parent_device"] > 0
            and type(value["parent_inode"]) is int
            and value["parent_inode"] > 0
            and (
                (value["scope_device"] is None and value["scope_inode"] is None)
                or (
                    type(value["scope_device"]) is int
                    and value["scope_device"] > 0
                    and type(value["scope_inode"]) is int
                    and value["scope_inode"] > 0
                )
            )
        )
        if not valid:
            return False
        is_created = value["scope_device"] is not None
        return created is None or created == is_created

    def _verify_parent(self, scope: dict[str, Any]) -> Path:
        if not self.shape(scope):
            raise BrokerError("invalid operation cgroup identity")
        self._mount_is_cgroup2()
        parent = Path(scope["parent_path"])
        info = parent.lstat()
        if (
            parent.is_symlink()
            or not stat.S_ISDIR(info.st_mode)
            or info.st_uid != self.expected_uid
            or (info.st_dev, info.st_ino)
            != (scope["parent_device"], scope["parent_inode"])
        ):
            raise BrokerError("operation cgroup parent identity changed")
        return parent

    def create(self, planned: dict[str, Any]) -> dict[str, Any]:
        if not self.shape(planned, created=False):
            raise BrokerError("invalid planned operation cgroup")
        parent = self._verify_parent(planned)
        scope = Path(planned["scope_path"])
        try:
            os.mkdir(scope, 0o755)
        except OSError as exc:
            raise BrokerError("cannot create exact operation cgroup") from exc
        info = scope.lstat()
        created = {**planned, "scope_device": info.st_dev, "scope_inode": info.st_ino}
        try:
            self._verify_scope(created)
        except BaseException:
            try:
                os.rmdir(scope)
            except OSError:
                pass
            raise
        return created

    def _verify_scope(self, scope: dict[str, Any]) -> Path:
        if not self.shape(scope, created=True):
            raise BrokerError("invalid created operation cgroup")
        self._verify_parent(scope)
        path = Path(scope["scope_path"])
        info = path.lstat()
        if (
            path.is_symlink()
            or not stat.S_ISDIR(info.st_mode)
            or info.st_uid != self.expected_uid
            or (info.st_dev, info.st_ino)
            != (scope["scope_device"], scope["scope_inode"])
        ):
            raise BrokerError("operation cgroup identity changed")
        for name in ("cgroup.events", "cgroup.kill", "cgroup.procs"):
            control = path / name
            control_info = control.stat()
            if (
                not stat.S_ISREG(control_info.st_mode)
                or control_info.st_uid != self.expected_uid
            ):
                raise BrokerError(f"unsafe operation cgroup control: {name}")
        return path

    def _write_control(self, path: Path, value: bytes) -> None:
        flags = os.O_WRONLY | os.O_CLOEXEC | getattr(os, "O_NOFOLLOW", 0)
        fd = os.open(path, flags)
        try:
            info = os.fstat(fd)
            if not stat.S_ISREG(info.st_mode) or info.st_uid != self.expected_uid:
                raise BrokerError(f"unsafe operation cgroup control: {path.name}")
            if os.write(fd, value) != len(value):
                raise BrokerError(f"short operation cgroup control write: {path.name}")
        finally:
            os.close(fd)

    def attach(self, scope: dict[str, Any], pid: int) -> None:
        path = self._verify_scope(scope)
        self._write_control(path / "cgroup.procs", f"{pid}\n".encode("ascii"))
        membership = self._read_bounded(self.proc_root / str(pid) / "cgroup", 16_384)
        expected = "0::/" + str(path.relative_to(self.mount_root))
        if membership.strip() != expected:
            raise BrokerError("operation guard did not enter its exact cgroup")

    def contains(self, scope: dict[str, Any], pid: int) -> bool:
        try:
            path = self._verify_scope(scope)
            membership = self._read_bounded(
                self.proc_root / str(pid) / "cgroup", 16_384
            )
        except (BrokerError, OSError):
            return False
        expected = "0::/" + str(path.relative_to(self.mount_root))
        return membership.strip() == expected

    def populated(self, scope: dict[str, Any]) -> bool:
        path = self._verify_scope(scope)
        events = self._read_bounded(path / "cgroup.events", 4_096)
        values: dict[str, str] = {}
        for row in events.splitlines():
            fields = row.split()
            if len(fields) == 2:
                values[fields[0]] = fields[1]
        if values.get("populated") not in {"0", "1"}:
            raise BrokerError("operation cgroup has invalid populated state")
        return values["populated"] == "1"

    def reconcile(self, scope: dict[str, Any], timeout: float) -> None:
        path = Path(scope["scope_path"])
        try:
            self._verify_scope(scope)
        except FileNotFoundError:
            raise BrokerError("recorded operation cgroup is absent")
        if self.populated(scope):
            self._write_control(path / "cgroup.kill", b"1\n")
        deadline = time.monotonic() + timeout
        while self.populated(scope) and time.monotonic() < deadline:
            self.sleeper(0.05)
        if self.populated(scope):
            raise BrokerError("operation cgroup remains populated after cgroup.kill")
        try:
            os.rmdir(path)
        except OSError as exc:
            raise BrokerError("empty operation cgroup could not be removed") from exc
        try:
            parent = Path(scope["parent_path"])
            os.rmdir(parent)
        except OSError:
            pass


@dataclass(frozen=True, slots=True)
class Request:
    operation: str
    mode: str
    caller_uid: int
    release_id: str
    owner_epoch: str
    generation: int
    listen_port: int
    contract_digest: str = "0" * 64
    vpn_max_tries: int = 1
    vpn_ranking_version: str = _VPN_RANKING_VERSION
    vpn_countries: tuple[str, ...] = ()
    vpn_prefer_countries: tuple[str, ...] = ()
    vpn_blocked_countries: tuple[str, ...] = ()
    caller_pid: int = 0
    caller_start_ticks: int = 0
    caller_boot_id: str = ""
    deadline_monotonic_ns: int = 0

    def validate(self) -> None:
        if self.operation not in _OPERATIONS:
            raise BrokerError("unsupported broker operation")
        if self.mode not in _MODES:
            raise BrokerError("unsupported broker mode")
        if type(self.caller_uid) is not int or not 0 <= self.caller_uid <= 2**31 - 1:
            raise BrokerError("invalid caller UID")
        if _RELEASE.fullmatch(self.release_id) is None:
            raise BrokerError("invalid release ID")
        if _TOKEN.fullmatch(self.owner_epoch) is None:
            raise BrokerError("invalid owner epoch")
        if type(self.generation) is not int or not 0 <= self.generation <= 2**63 - 1:
            raise BrokerError("invalid generation")
        if type(self.listen_port) is not int or not _MIN_PORT <= self.listen_port <= _MAX_PORT:
            raise BrokerError("invalid private relay port")
        if self.operation == "migrate-legacy" and self.mode != "compatibility-handoff":
            raise BrokerError("legacy migration requires compatibility-handoff mode")
        if self.mode == "compatibility-handoff" and self.operation != "migrate-legacy":
            raise BrokerError("compatibility-handoff mode permits only legacy migration")
        if self.mode == "compatibility":
            if self.owner_epoch != f"compat-{self.caller_uid}" or self.generation != 0:
                raise BrokerError("invalid compatibility owner identity")
        elif self.mode == "compatibility-handoff":
            if self.generation != 1 or self.listen_port != 1080:
                raise BrokerError("invalid compatibility-handoff identity")
        elif self.generation == 0:
            raise BrokerError("supervisor generation must be positive")
        if _RELEASE.fullmatch(self.contract_digest) is None:
            raise BrokerError("invalid canonical contract digest")
        if type(self.vpn_max_tries) is not int or not 1 <= self.vpn_max_tries <= _MAX_VPN_TRIES:
            raise BrokerError("invalid VPN candidate cap")
        if self.vpn_ranking_version != _VPN_RANKING_VERSION:
            raise BrokerError("unsupported VPN ranking version")
        for label, countries in (
            ("allowed", self.vpn_countries),
            ("preferred", self.vpn_prefer_countries),
            ("blocked", self.vpn_blocked_countries),
        ):
            if (
                type(countries) is not tuple
                or len(set(countries)) != len(countries)
                or any(type(country) is not str or _COUNTRY.fullmatch(country) is None for country in countries)
            ):
                raise BrokerError(f"invalid {label} VPN country policy")
        if set(self.vpn_countries) & set(self.vpn_blocked_countries):
            raise BrokerError("allowed and blocked VPN countries overlap")
        caller_fields = (
            self.caller_pid,
            self.caller_start_ticks,
            self.caller_boot_id,
            self.deadline_monotonic_ns,
        )
        if caller_fields != (0, 0, "", 0):
            if (
                type(self.caller_pid) is not int
                or not 1 <= self.caller_pid <= 2**31 - 1
                or type(self.caller_start_ticks) is not int
                or not 1 <= self.caller_start_ticks <= 2**63 - 1
                or _BOOT_ID.fullmatch(self.caller_boot_id) is None
                or type(self.deadline_monotonic_ns) is not int
                or not 1 <= self.deadline_monotonic_ns <= 2**63 - 1
            ):
                raise BrokerError("invalid exact caller/deadline identity")

    def vpn_policy_record(self) -> dict[str, Any]:
        return {
            "blocked_countries": list(self.vpn_blocked_countries),
            "countries": list(self.vpn_countries),
            "max_tries": self.vpn_max_tries,
            "prefer_countries": list(self.vpn_prefer_countries),
            "ranking_version": self.vpn_ranking_version,
        }


