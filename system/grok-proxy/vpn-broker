def _bounded_failure_detail(payload: bytes, returncode: int) -> str:
    """Describe hostile helper output without replaying its content."""

    return (
        f"exit={returncode} output_bytes={len(payload)} "
        f"output_sha256={hashlib.sha256(payload).hexdigest()}"
    )


def _name_set_fingerprint(names: set[str]) -> str:
    """Hash directory-entry identities without replaying hostile names."""

    digest = hashlib.sha256()
    for raw in sorted(os.fsencode(name) for name in names):
        digest.update(len(raw).to_bytes(8, "big"))
        digest.update(raw)
    return digest.hexdigest()


