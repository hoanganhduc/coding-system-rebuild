{
  "mcpServers": {
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "github": {
      "command": "bash",
      "args": [
        "-c",
        "GITHUB_TOKEN=$(gh auth token 2>/dev/null) exec npx -y @modelcontextprotocol/server-github"
      ],
      "env": {}
    },
    "docling": {
      "command": "{{ HOME }}/.local/share/docling-venv/bin/python",
      "args": [
        "-m",
        "docling_mcp"
      ],
      "env": {
        "TESSDATA_PREFIX": "/usr/share/tesseract-ocr/5/tessdata/"
      }
    },
    "scrapling": {
      "command": "uvx",
      "args": [
        "scrapling",
        "mcp"
      ]
    }
  }
}
