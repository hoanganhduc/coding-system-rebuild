{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.codex/hooks/codex-session-start-context.sh",
            "statusMessage": "Loading Codex workflow context"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.codex/hooks/codex-pre-bash-safety.py",
            "statusMessage": "Checking Bash command safety"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.codex/hooks/codex-post-bash-errors.py",
            "statusMessage": "Reviewing Bash output"
          }
        ]
      }
    ]
  }
}
